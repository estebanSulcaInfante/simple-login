@model LoginFrontend.Models.Usuario

@{
    ViewData["Title"] = "Perfil Institucional";
    Layout = "_LayoutDashboard";
}

<div class="overflow-x-hidden pb-3">
<!-- Hero Header -->
<div class="mb-5 d-flex flex-column flex-md-row justify-content-md-between align-items-md-end gap-3 gap-md-0">
    <div>
        <h1 class="font-headline fw-bolder text-primary-custom tracking-tight mb-2" style="font-size: 2.25rem;">Perfil de Usuario</h1>
        <p class="text-on-surface-variant fw-medium m-0">Revise y gestione su identidad institucional y credenciales de acceso.</p>
    </div>
    <div class="d-flex flex-wrap gap-3">
        <button class="btn btn-outline-secondary border-outline-variant text-secondary-custom fw-semibold px-4 py-2 rounded-3 hover-bg-surface-container-low transition-all bg-white border-opacity-25 shadow-sm">
            Solicitar Edición
        </button>
        <button class="btn premium-gradient text-white fw-semibold px-4 py-2 rounded-3 shadow hover-scale-101 active-scale-95 transition-all">
            Actualizar Identidad
        </button>
    </div>
</div>

<!-- Bento Grid -->
<div class="row g-5 pb-5">
    
    <!-- Section 1: Personal Data -->
    <section class="col-12">
        <div class="bg-surface-container-lowest rounded-4 p-4 p-lg-5 shadow-sm ring-1">
            <div class="d-flex align-items-center gap-3 mb-5">
                <div class="rounded-pill" style="height: 3rem; width: 0.375rem; background-color: #e9c176;"></div> <!-- tertiary-fixed-dim -->
                <h2 class="font-headline fw-bold text-primary-custom fs-4 m-0">Datos Personales</h2>
            </div>
            
            <!-- Badge block -->
            <div class="d-flex flex-column flex-md-row align-items-center gap-4 gap-md-5 mb-5 p-4 bg-surface-container-low rounded-4">
                <div class="position-relative">
                    <img class="rounded-4 object-fit-cover shadow-sm bg-white border border-4 border-white" 
                         src="@(string.IsNullOrEmpty(Model.FotoUrl) ? "https://lh3.googleusercontent.com/aida-public/AB6AXuCFnukPQ2yDu9jkG9l8Cqx7KUQruAkumhLswT_cAELqweZW07Loy3yJeRZ0u92WlOpGvXUYXF1aVsgtTaECy6RTkOpNd0tQL9lAbkpS03BtwkYk6hKbShkFofPBWynSMJ7Wg7nF5xidv47wJs7VAR0UZCvxHFgr27E2w42nqoEtgLwBX12NySGu2O5FM3AzjDkvSqvFBYbpOJScAuv87jIs1JqdhekBfuSYFhpRelM_AQi68aYLvbNe_Nb4c2I9ZzLfZSH5YciG3cM" : Model.FotoUrl)" 
                         alt="Avatar" style="height: 6rem; width: 6rem;" />
                    <div class="position-absolute bottom-0 end-0 bg-primary-custom text-white p-1 rounded-2 shadow-lg" style="transform: translate(25%, 25%); cursor: pointer;">
                        <span class="material-symbols-outlined fs-6 d-block">photo_camera</span>
                    </div>
                </div>
                <div class="text-center text-md-start">
                    <h3 class="font-headline fw-bold text-primary-custom fs-5 m-0 mb-2">@Model.Nombres @Model.PrimerApellido</h3>
                    <span class="d-inline-block px-3 py-1 bg-secondary-container text-on-secondary-container fw-bold rounded-pill text-uppercase tracking-tighter" style="font-size: 0.65rem;">
                        Identidad Verificada
                    </span>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4 g-lg-5">
                <div class="col d-flex flex-column gap-1">
                    <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Nombres</label>
                    <p class="fw-medium text-primary-custom fs-5 m-0">@Model.Nombres</p>
                </div>
                <div class="col d-flex flex-column gap-1">
                    <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Apellidos</label>
                    <p class="fw-medium text-primary-custom fs-5 m-0">@Model.PrimerApellido @Model.SegundoApellido</p>
                </div>
                <div class="col d-flex flex-column gap-1">
                    <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Nacionalidad</label>
                    <p class="fw-medium text-primary-custom fs-5 m-0">@Model.Nacionalidad</p>
                </div>
                <div class="col d-flex flex-column gap-1">
                    <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Número de Documento</label>
                    <p class="fw-medium text-primary-custom fs-5 m-0">@Model.TipoDocumento-@Model.NumeroDocumento</p>
                </div>
                <div class="col d-flex flex-column gap-1">
                    <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Fecha de Nacimiento</label>
                    <p class="fw-medium text-primary-custom fs-5 m-0">@Model.FechaNacimiento</p>
                </div>
                <div class="col d-flex flex-column gap-1">
                    <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Sexo</label>
                    <p class="fw-medium text-primary-custom fs-5 m-0">@Model.Sexo</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 2: Institutional & Contact Data -->
    <section class="col-12">
        <div class="bg-surface-container-lowest rounded-4 p-4 p-lg-5 shadow-sm ring-1">
            <div class="d-flex align-items-center gap-3 mb-5">
                <div class="rounded-pill bg-secondary-custom" style="height: 3rem; width: 0.375rem;"></div>
                <h2 class="font-headline fw-bold text-primary-custom fs-4 m-0">Datos Institucionales y de Contacto</h2>
            </div>

            <div class="row g-5">
                <!-- Column 1: Roles -->
                <div class="col-12 col-md-4 d-flex flex-column gap-4">
                    <div class="p-4 bg-surface-container-low rounded-4 border-start border-4 border-primary">
                        <label class="fw-black text-primary-custom text-uppercase d-block mb-2" style="font-size: 0.6rem; letter-spacing: 0.2em;">Entidad Actual</label>
                        <p class="font-headline fw-bold text-primary-custom fs-5 lh-sm m-0">@Model.Entidad</p>
                        <p class="text-on-surface-variant mt-2 mb-0 small" style="font-size: 0.8rem;">División: Registro Interno</p>
                    </div>
                    <div class="px-2 d-flex flex-column gap-1">
                        <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Rol Corporativo</label>
                        <p class="fw-medium text-primary-custom m-0">@Model.Cargo</p>
                    </div>
                </div>

                <!-- Column 2: Contact -->
                <div class="col-12 col-md-4 d-flex flex-column gap-4">
                    <div class="px-2 d-flex flex-column gap-1">
                        <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Correo Principal</label>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-secondary-custom fs-6">mail</span>
                            <p class="fw-medium text-primary-custom m-0 text-truncate">@Model.Email</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.EmailSecundario))
                    {
                        <div class="px-2 d-flex flex-column gap-1">
                            <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Correo Alternativo</label>
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined text-secondary-custom fs-6">mail</span>
                                <p class="fw-medium text-primary-custom m-0 text-truncate">@Model.EmailSecundario</p>
                            </div>
                        </div>
                    }
                    <div class="px-2 d-flex flex-column gap-1">
                        <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Número de Teléfono</label>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-secondary-custom fs-6">call</span>
                            <p class="fw-medium text-primary-custom m-0">@Model.TelefonoMovil</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.TelefonoSecundario))
                    {
                        <div class="px-2 d-flex flex-column gap-1">
                            <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Teléfono Secundario</label>
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined text-secondary-custom fs-6">phone_iphone</span>
                                <p class="fw-medium text-primary-custom m-0">@Model.TelefonoSecundario <span class="text-on-surface-variant small">(@Model.TelefonoSecundarioTipo)</span></p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Column 3: Employment Details -->
                <div class="col-12 col-md-4 d-flex flex-column gap-4">
                    <div class="px-2">
                        <label class="font-label fw-bold text-on-surface-variant text-uppercase tracking-widest mb-3 d-block" style="font-size: 0.65rem;">Detalles de Empleo</label>
                        <div class="d-flex flex-column gap-3">
                            <div>
                                <label class="fw-bold text-on-surface-variant text-uppercase tracking-widest mb-1 d-block" style="font-size: 0.6rem;">Fecha de Contratación</label>
                                <p class="fw-medium text-primary-custom m-0">@Model.FechaContratacion</p>
                            </div>
                            <div>
                                <label class="fw-bold text-on-surface-variant text-uppercase tracking-widest mb-1 d-block" style="font-size: 0.6rem;">Tipo de Contrato</label>
                                <p class="fw-medium text-primary-custom m-0">@Model.TipoContratacion</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
</div> <!-- End Overflow wrapper -->

<!-- Modal Inactividad (Re-engineered to Institutional standard) -->
<div id="sessionModal" class="position-fixed bottom-0 end-0 z-100 p-4" style="max-width: 25rem; display: none;">
    <div class="bg-white rounded-4 shadow-lg border border-outline-variant p-4 backdrop-blur-xl overflow-hidden position-relative animate-slide-up">
        <!-- Progress bar -->
        <div id="sessionProgressBar" class="position-absolute top-0 start-0 bg-danger" style="height: 0.35rem; width: 100%; transition: width 1s linear;"></div>
        
        <div class="d-flex align-items-start gap-3">
            <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center shrink-0" style="width: 2.5rem; height: 2.5rem;">
                <span class="material-symbols-outlined text-danger icon-fill-1">timer</span>
            </div>
            <div>
                <h5 class="font-headline fw-bold text-primary-custom mb-1 fs-6">Alerta de Seguridad</h5>
                <p class="small text-on-surface-variant lh-base m-0">Su sesión está a punto de caducar por inactividad.</p>
                <div class="mt-3 d-flex align-items-center gap-2">
                    <span id="countdownDisplay" class="fs-2 fw-black font-headline text-danger lh-1">30</span>
                    <span class="small fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Segundos Restantes</span>
                </div>
                <!-- Controls -->
                <div class="mt-4 d-flex gap-2">
                    <button id="btnRenew" class="btn bg-primary-custom text-white fw-bold text-uppercase w-100" style="font-size: 0.70rem; padding: 0.5rem 1rem;">
                        Renovar Sesión
                    </button>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-outline-secondary text-on-surface-variant fw-bold text-uppercase h-100 px-3" style="font-size: 0.70rem;">
                            Cerrar Sesión
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Constants in milliseconds
        const SESSION_DURATION_MS = 60000;      // 1 minute total session allowed (for testing)
        const WARNING_BEFORE_MS = 30000;        // show warning 30 seconds before it expires
        const COUNTDOWN_SECONDS = WARNING_BEFORE_MS / 1000;

        let sessionTimer;
        let countdownInterval;
        let countdownValue = COUNTDOWN_SECONDS;

        const sessionModal = document.getElementById('sessionModal');
        const countdownDisplay = document.getElementById('countdownDisplay');
        const btnRenew = document.getElementById('btnRenew');
        const sessionProgressBar = document.getElementById('sessionProgressBar');

        function startSessionTimer() {
            // Setup the trigger to show the modal `WARNING_BEFORE_MS` before expired.
            const timeoutValue = SESSION_DURATION_MS - WARNING_BEFORE_MS;

            sessionTimer = setTimeout(() => {
                showModal();
            }, timeoutValue);
        }

        function showModal() {
            sessionModal.style.display = 'block';
            countdownValue = COUNTDOWN_SECONDS;
            updateCountdownDisplay();

            countdownInterval = setInterval(() => {
                countdownValue--;
                updateCountdownDisplay();

                if (countdownValue <= 0) {
                    clearInterval(countdownInterval);
                    // Force logout or let server reject them on next request.
                    // Doing a frontend redirection to login:
                    window.location.href = '@Url.Action("Login", "Account")?expired=true';
                }
            }, 1000);
        }

        function updateCountdownDisplay() {
            countdownDisplay.innerText = countdownValue;
            
            // Update progress bar width
            const percentage = (countdownValue / COUNTDOWN_SECONDS) * 100;
            sessionProgressBar.style.width = percentage + '%';
        }

        function hideModal() {
            sessionModal.style.display = 'none';
            clearInterval(countdownInterval);
        }

        // Renew Session Action
        btnRenew.addEventListener('click', () => {
             // AJAX call to refresh the server cookie/session
            fetch('@Url.Action("ExtendSession", "Users")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
                .then(response => {
                    if (response.ok) {
                        // Successfully extended
                        hideModal();
                        clearTimeout(sessionTimer);
                        startSessionTimer(); // Restart the cycle
                    } else {
                        // Error extending
                        window.location.href = '@Url.Action("Login", "Account")?expired=true';
                    }
                })
                .catch(error => {
                    console.error('Error al extender sesión:', error);
                });
        });

        // Start cycle initially
        startSessionTimer();
    </script>
}
