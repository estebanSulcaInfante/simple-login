@model LoginFrontend.Models.Usuario

@{
    ViewData["Title"] = "Perfil Institucional";
    Layout = "_LayoutDashboard";
}

<div class="overflow-x-hidden pb-3">
<!-- Breadcrumb / Context inside the padded container -->
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb m-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-secondary-custom fw-bold">Módulo PEI</a></li>
            <li class="breadcrumb-item active fw-medium text-slate-500" aria-current="page">Perfil de usuario</li>
        </ol>
    </nav>
</div>

<!-- Profile Header -->
<div class="bg-surface-container-lowest rounded-4 p-4 shadow-sm ring-1 mb-3 position-relative overflow-hidden">
    <!-- Decorative accent -->
    <div class="position-absolute top-0 start-0 h-100" style="width: 0.375rem; background-color: #8B1A1A;"></div>
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 ps-2">
        <div>
            <div class="d-flex flex-wrap align-items-center gap-3 mb-1">
                <h1 class="font-headline fw-bolder text-primary-custom m-0" style="font-size: 1.75rem;">@Model.PrimerApellido @Model.SegundoApellido, @Model.Nombres</h1>
                @if(Model.Activo) {
                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-1 rounded-pill fw-bold tracking-widest text-uppercase" style="font-size: 0.7rem;">
                        Activo
                    </span>
                } else {
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-1 rounded-pill fw-bold tracking-widest text-uppercase" style="font-size: 0.7rem;">
                        Inactivo
                    </span>
                }
            </div>
            
            <p class="text-on-surface-variant fw-medium m-0 mt-2">
                Resultado de búsqueda: <span class="fw-bold text-slate-800">@Model.Cargo</span>
            </p>
            <p class="text-on-surface-variant fw-medium m-0 mt-1">
                011 @Model.Entidad
            </p>
        </div>
        
        <div class="d-flex flex-shrink-0 gap-2">
            <button class="btn btn-outline-secondary border-outline-variant text-secondary-custom fw-semibold px-4 py-2 rounded-3 hover-bg-surface-container-low transition-all bg-white shadow-sm">
                <span class="material-symbols-outlined fs-6 me-2 align-middle">edit</span> Editar Perfil
            </button>
        </div>
    </div>
</div>

<!-- Tabs Navigation -->
<ul class="nav nav-tabs border-outline-variant mb-4 font-headline fw-bold" id="profileTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active text-primary-custom px-4 py-3" id="basic-info-tab" data-bs-toggle="tab" data-bs-target="#basic-info" type="button" role="tab">Información básica</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link text-slate-500 px-4 py-3 hover-text-primary-custom transition-colors" id="responsibilities-tab" data-bs-toggle="tab" data-bs-target="#responsibilities" type="button" role="tab">Responsabilidades</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link text-slate-500 px-4 py-3 hover-text-primary-custom transition-colors" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">Historial de responsabilidades</button>
    </li>
</ul>

<!-- Tabs Content -->
<div class="tab-content" id="profileTabsContent">
    <!-- Tab 1: Información Básica -->
    <div class="tab-pane fade show active" id="basic-info" role="tabpanel" tabindex="0">
        <div class="bg-surface-container-lowest rounded-4 p-4 shadow-sm ring-1 mb-4">
            
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Nombres</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.Nombres</div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Primer Apellido</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.PrimerApellido</div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Segundo Apellido</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.SegundoApellido</div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Tipo de Documento de Identidad</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.TipoDocumento</div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">N° de Documento de Identidad</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.NumeroDocumento</div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Fecha de nacimiento</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.FechaNacimiento</div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Nacionalidad</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.Nacionalidad</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Sexo</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.Sexo</div>
                </div>
            </div>

            <hr class="border-outline-variant my-4 opacity-50" />

            <div class="row g-3 mb-4">
                <div class="col-12 col-lg-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Correo electrónico principal</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant text-truncate">@Model.Email</div>
                </div>
                <div class="col-12 col-lg-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Correo electrónico secundario</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant text-truncate">@(string.IsNullOrEmpty(Model.EmailSecundario) ? "-" : Model.EmailSecundario)</div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Teléfono Móvil</label>
                    <div class="d-flex justify-content-between align-items-center fw-medium text-slate-900 fs-6 bg-surface-container-low py-2 px-3 rounded-3 border border-outline-variant">
                        <span>@(!string.IsNullOrEmpty(Model.TelefonoMovil) ? Model.TelefonoMovil : "+51 999 999 999")</span>
                        <a href="#" class="text-primary-custom text-decoration-none d-flex align-items-center hover-scale-101 transition-all" title="Editar teléfono móvil">
                            <span class="material-symbols-outlined fs-5">edit</span>
                        </a>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Teléfono secundario</label>
                    <div class="d-flex gap-2">
                        <!-- Select 'Tipo' block -->
                        <div class="d-flex justify-content-between align-items-center bg-white py-2 px-3 rounded-3 border border-outline-variant text-slate-500 hover-bg-surface-container-lowest transition-colors" style="min-width: 100px; cursor: pointer;">
                            <span class="fs-6 fw-medium me-1">Tipo</span>
                            <span class="material-symbols-outlined fs-5">expand_more</span>
                        </div>
                        <!-- Empty value block -->
                        <div class="d-flex flex-grow-1 align-items-center bg-surface-container-low py-2 px-3 rounded-3 border border-outline-variant">
                            <span class="text-slate-900 fw-medium">@(string.IsNullOrEmpty(Model.TelefonoSecundario) ? "" : Model.TelefonoSecundario)</span>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="border-outline-variant my-4 opacity-50" />
            
            <h3 class="font-headline fw-bold text-primary-custom fs-5 mb-3">Tipo</h3>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Tipo de Contratación</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.TipoContratacion</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="font-label fw-bold text-slate-500 small d-block mb-1">Fecha de contratación</label>
                    <div class="fw-medium text-slate-900 fs-6 bg-surface-container-low p-2 px-3 rounded-3 border border-outline-variant">@Model.FechaContratacion</div>
                </div>
            </div>

        </div>
    </div>
    
    <!-- Tab 2: Responsabilidades -->
    <div class="tab-pane fade" id="responsibilities" role="tabpanel" tabindex="0">
        <div class="bg-surface-container-lowest rounded-4 p-4 shadow-sm ring-1 mb-4 text-center">
            <span class="material-symbols-outlined text-slate-300 mb-2" style="font-size: 2.5rem;">assignment</span>
            <h4 class="font-headline fw-bold text-slate-700 fs-6 mb-1">No hay responsabilidades activas</h4>
            <p class="text-slate-500 m-0 small">El usuario actualmente no tiene responsabilidades asignadas en el módulo PEI.</p>
        </div>
    </div>
    
    <!-- Tab 3: Historial -->
    <div class="tab-pane fade" id="history" role="tabpanel" tabindex="0">
        <div class="bg-surface-container-lowest rounded-4 p-4 shadow-sm ring-1 mb-4 text-center">
            <span class="material-symbols-outlined text-slate-300 mb-2" style="font-size: 2.5rem;">history</span>
            <h4 class="font-headline fw-bold text-slate-700 fs-6 mb-1">Historial vacío</h4>
            <p class="text-slate-500 m-0 small">No se encontraron registros de responsabilidades pasadas para este usuario.</p>
        </div>
    </div>
</div>
</div> <!-- End Overflow wrapper -->

<!-- Modal Inactividad (Re-engineered to Institutional standard) -->
<div id="sessionModal" class="position-fixed bottom-0 end-0 z-100 p-4" style="max-width: 25rem; display: none;">
    <div class="bg-white rounded-4 shadow-lg border border-outline-variant p-4 backdrop-blur-xl overflow-hidden position-relative animate-slide-up">
        <!-- Progress bar -->
        <div id="sessionProgressBar" class="position-absolute top-0 start-0 bg-danger" style="height: 0.35rem; width: 100%; transition: width 1s linear;"></div>
        
        <div class="d-flex align-items-start gap-3">
            <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center shrink-0" style="width: 2.5rem; height: 2.5rem;">
                <span class="material-symbols-outlined text-danger icon-fill-1">timer</span>
            </div>
            <div>
                <h5 class="font-headline fw-bold text-primary-custom mb-1 fs-6">Alerta de Seguridad</h5>
                <p class="small text-on-surface-variant lh-base m-0">Su sesión está a punto de caducar por inactividad.</p>
                <div class="mt-3 d-flex align-items-center gap-2">
                    <span id="countdownDisplay" class="fs-2 fw-black font-headline text-danger lh-1">30</span>
                    <span class="small fw-bold text-on-surface-variant text-uppercase tracking-widest" style="font-size: 0.65rem;">Segundos Restantes</span>
                </div>
                <!-- Controls -->
                <div class="mt-4 d-flex gap-2">
                    <button id="btnRenew" class="btn bg-primary-custom text-white fw-bold text-uppercase w-100" style="font-size: 0.70rem; padding: 0.5rem 1rem;">
                        Renovar Sesión
                    </button>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-outline-secondary text-on-surface-variant fw-bold text-uppercase h-100 px-3" style="font-size: 0.70rem;">
                            Cerrar Sesión
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Constants in milliseconds
        const SESSION_DURATION_MS = 60000;      // 1 minute total session allowed (for testing)
        const WARNING_BEFORE_MS = 30000;        // show warning 30 seconds before it expires
        const COUNTDOWN_SECONDS = WARNING_BEFORE_MS / 1000;

        let sessionTimer;
        let countdownInterval;
        let countdownValue = COUNTDOWN_SECONDS;

        const sessionModal = document.getElementById('sessionModal');
        const countdownDisplay = document.getElementById('countdownDisplay');
        const btnRenew = document.getElementById('btnRenew');
        const sessionProgressBar = document.getElementById('sessionProgressBar');

        function startSessionTimer() {
            // Setup the trigger to show the modal `WARNING_BEFORE_MS` before expired.
            const timeoutValue = SESSION_DURATION_MS - WARNING_BEFORE_MS;

            sessionTimer = setTimeout(() => {
                showModal();
            }, timeoutValue);
        }

        function showModal() {
            sessionModal.style.display = 'block';
            countdownValue = COUNTDOWN_SECONDS;
            updateCountdownDisplay();

            countdownInterval = setInterval(() => {
                countdownValue--;
                updateCountdownDisplay();

                if (countdownValue <= 0) {
                    clearInterval(countdownInterval);
                    // Force logout or let server reject them on next request.
                    // Doing a frontend redirection to login:
                    window.location.href = '@Url.Action("Login", "Account")?expired=true';
                }
            }, 1000);
        }

        function updateCountdownDisplay() {
            countdownDisplay.innerText = countdownValue;
            
            // Update progress bar width
            const percentage = (countdownValue / COUNTDOWN_SECONDS) * 100;
            sessionProgressBar.style.width = percentage + '%';
        }

        function hideModal() {
            sessionModal.style.display = 'none';
            clearInterval(countdownInterval);
        }

        // Renew Session Action
        btnRenew.addEventListener('click', () => {
             // AJAX call to refresh the server cookie/session
            fetch('@Url.Action("ExtendSession", "Users")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
                .then(response => {
                    if (response.ok) {
                        // Successfully extended
                        hideModal();
                        clearTimeout(sessionTimer);
                        startSessionTimer(); // Restart the cycle
                    } else {
                        // Error extending
                        window.location.href = '@Url.Action("Login", "Account")?expired=true';
                    }
                })
                .catch(error => {
                    console.error('Error al extender sesión:', error);
                });
        });

        // Start cycle initially
        startSessionTimer();
    </script>
}
