@using System.Text.Json
<!DOCTYPE html>
<html lang="es" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Institutional Vanguard</title>

    <!-- Google Fonts: Manrope (Headlines) & Inter (Body) -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Inter:wght@100..900&display=swap" rel="stylesheet" />
    <!-- Material Symbols Outlined -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <!-- Custom CSS (Tailwind translated concepts) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-surface text-on-surface font-body min-vh-100 d-flex flex-column">
    
    <!-- TopNavBar -->
    <header class="bg-white-80 backdrop-blur-xl shadow-sm fixed-top w-100 d-flex justify-content-between align-items-center px-4 px-md-5 h-20 z-50">
        <div class="d-flex align-items-center gap-2">
            <span class="font-headline fw-black text-slate-900 fs-5 tracking-tighter">Institutional Vanguard</span>
        </div>
        <div class="d-flex align-items-center gap-4">
            <a href="#" class="text-slate-500 text-decoration-none hover-text-slate-700 font-label small text-uppercase tracking-widest transition-all d-none d-sm-block">Support</a>
        </div>
    </header>

    <!-- Main Content Canvas -->
    <main class="flex-grow-1 d-flex flex-column align-items-center justify-content-center pt-24 pb-12 px-3 px-sm-4 px-lg-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-slate-50 w-100 py-5 border-top border-slate-200 mt-auto">
        <div class="container-xl px-4 px-md-5 d-flex flex-column flex-md-row justify-content-between align-items-center gap-4">
            <div class="d-flex flex-column align-items-center align-items-md-start gap-2">
                <span class="font-headline fw-bold text-slate-900">Institutional Vanguard</span>
                <p class="font-label small text-uppercase tracking-widest text-slate-500 m-0">© 2024 Institutional Vanguard. All rights reserved.</p>
            </div>
            <div class="d-flex gap-4">
                <a href="#" class="font-label small text-uppercase tracking-widest text-slate-500 text-decoration-none hover-text-slate-700 hover-underline transition-all">Privacy Policy</a>
                <a href="#" class="font-label small text-uppercase tracking-widest text-slate-500 text-decoration-none hover-text-slate-700 hover-underline transition-all">Terms of Service</a>
                <a href="#" class="font-label small text-uppercase tracking-widest text-slate-500 text-decoration-none hover-text-slate-700 hover-underline transition-all">Institutional Identity</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
