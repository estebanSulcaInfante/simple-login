<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEPLAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="layout-simple">
    <!-- Top red header bar -->
    <header class="top-header">
        <div class="header-left">
            <img src="/img/ceplan-logo.svg" alt="CEPLAN" class="header-logo" onerror="this.style.display='none'" />
        </div>
        <div class="header-right">
            <button class="btn-help" title="Ayuda">?</button>
        </div>
    </header>

    <!-- Main content area with background -->
    <main class="main-simple">
        <div class="bg-landscape"></div>
        <div class="content-wrapper">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="gov-footer">
        <div class="footer-content">
            <div class="footer-logos">
                <div class="footer-item">
                    <img src="/img/escudo-peru.svg" alt="Escudo del Perú" class="footer-escudo" onerror="this.outerHTML='<span class=\'footer-shield\'>🇵🇪</span>'" />
                    <span class="footer-peru-text">PERÚ</span>
                </div>
                <div class="footer-separator"></div>
                <div class="footer-item">
                    <span class="footer-org-text">Presidencia<br/>del Consejo de<br/>Ministros</span>
                </div>
                <div class="footer-separator"></div>
                <div class="footer-item">
                    <span class="footer-org-text">Centro Nacional<br/>de Planeamiento<br/>Estratégico</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
