@using System.Text.Json
<!DOCTYPE html>
<html lang="es" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Institutional Vanguard</title>

    <!-- Google Fonts: Manrope (Headlines) & Inter (Body) -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Inter:wght@100..900&display=swap" rel="stylesheet" />
    <!-- Material Symbols Outlined -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-surface text-on-surface font-body min-vh-100 d-flex flex-column">
    @{
        var usuarioActivo = Context.Items["UsuarioActivo"] as LoginFrontend.Models.Usuario;
    }
    <!-- TopNavBar Shell -->
    <header class="fixed-top w-100 d-flex justify-content-between align-items-center px-4 px-md-5 h-20 bg-white-80 backdrop-blur-xl shadow-sm z-50">
        <div class="d-flex align-items-center gap-4">
            <span class="font-headline fw-black text-slate-900 fs-5 tracking-tighter">Institutional Vanguard</span>
        </div>
        <div class="d-flex align-items-center gap-4">
            @if(usuarioActivo != null)
            {
                <div class="d-none d-md-flex flex-column align-items-end">
                    <span class="font-headline fw-bold fs-6 tracking-tight text-slate-900">@usuarioActivo.Nombres @usuarioActivo.PrimerApellido</span>
                    <span class="font-label small text-on-surface-variant text-uppercase tracking-wider">@usuarioActivo.Cargo</span>
                </div>
                <div class="avatar-lg rounded-circle overflow-hidden bg-surface-container-highest me-2">
                    <img class="w-100 h-100 object-fit-cover" src="@(string.IsNullOrEmpty(usuarioActivo.FotoUrl) ? "https://lh3.googleusercontent.com/aida-public/AB6AXuCFnukPQ2yDu9jkG9l8Cqx7KUQruAkumhLswT_cAELqweZW07Loy3yJeRZ0u92WlOpGvXUYXF1aVsgtTaECy6RTkOpNd0tQL9lAbkpS03BtwkYk6hKbShkFofPBWynSMJ7Wg7nF5xidv47wJs7VAR0UZCvxHFgr27E2w42nqoEtgLwBX12NySGu2O5FM3AzjDkvSqvFBYbpOJScAuv87jIs1JqdhekBfuSYFhpRelM_AQi68aYLvbNe_Nb4c2I9ZzLfZSH5YciG3cM" : usuarioActivo.FotoUrl)" alt="User Avatar" />
                </div>
            }
            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                <button type="submit" class="btn btn-icon group rounded-3 transition-colors hover-bg-slate-50 border-0 bg-transparent">
                    <span class="material-symbols-outlined text-slate-500 group-hover-text-error transition-colors">logout</span>
                </button>
            </form>
        </div>
    </header>

    <div class="d-flex flex-grow-1">
        <!-- SideNavBar Shell -->
        <aside class="sidebar-width d-none d-lg-flex flex-column position-fixed start-0 top-0 h-100 z-40 bg-primary-custom py-5 shadow-lg">
            <div class="px-4 mb-5">
                <div class="font-headline fw-black text-white fs-5">Portal Institucional</div>
                <div class="font-label small text-slate-400 text-uppercase tracking-widest mt-1 fw-bold" style="font-size: 0.65rem;">Consola de Gestión</div>
            </div>
            
            <nav class="flex-grow-1">
                <ul class="nav flex-column gap-1 w-100">
                    <li class="nav-item px-3 w-100">
                        <!-- Active State Applied to Profile -->
                        <a href="#" class="nav-link bg-sidebar-active text-white rounded-3 py-3 d-flex align-items-center px-3 transition-colors">
                            <span class="material-symbols-outlined me-3">person</span>
                            <span class="font-label small fw-medium">Perfil de usuario</span>
                        </a>
                    </li>
                    <li class="nav-item px-3 w-100">
                        <a href="#" class="nav-link text-slate-400 hover-text-white hover-bg-white-10 rounded-3 py-3 d-flex align-items-center px-3 transition-colors">
                            <span class="material-symbols-outlined me-3">group_add</span>
                            <span class="font-label small fw-medium">Módulo PEI</span>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <div class="mt-auto pt-4 border-top border-white-10">
                <ul class="nav flex-column gap-1 w-100">
                    <li class="nav-item px-3 w-100">
                        <a href="#" class="nav-link text-slate-400 hover-text-white hover-bg-white-10 rounded-3 py-3 d-flex align-items-center px-3 transition-colors">
                            <span class="material-symbols-outlined me-3">settings</span>
                            <span class="font-label small fw-medium">Configuración</span>
                        </a>
                    </li>
                    <li class="nav-item px-3 w-100">
                        <a href="#" class="nav-link text-slate-400 hover-text-white hover-bg-white-10 rounded-3 py-3 d-flex align-items-center px-3 transition-colors">
                            <span class="material-symbols-outlined me-3">help</span>
                            <span class="font-label small fw-medium">Soporte</span>
                        </a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="content-margin-left pt-24 min-vh-100 w-100 d-flex flex-column">
            @RenderBody()

            <!-- Footer Shell inside content to align with sidebar -->
            <footer class="bg-slate-50 border-top border-slate-200 mt-auto py-4">
                <div class="container-fluid px-4 px-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
                    <div class="font-body small text-slate-600 m-0" style="font-size: 0.85rem;">
                        Si necesitas ayuda comunicate con nosotros al Telf: (01) 2117-800 o a <a href="mailto:soporte@ceplan.gob.pe" class="text-secondary-custom text-decoration-none fw-bold hover-underline transition-all">soporte@ceplan.gob.pe</a>
                    </div>
                    <div class="d-flex flex-column align-items-md-end gap-1">
                        <span class="font-headline fw-bold text-slate-900 m-0" style="font-size: 0.95rem;">Presidencia del Consejo de Ministros</span>
                        <span class="font-label small text-slate-500 text-uppercase tracking-widest fw-bold" style="font-size: 0.65rem;">Centro Nacional de Planeamiento Estratégico</span>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
