<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEPLAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="layout-dashboard">
    <!-- Sidebar -->
    <aside class="sidebar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>
        <nav class="sidebar-nav">
            <a href="#" class="sidebar-link" title="Inicio">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </a>
            <a href="#" class="sidebar-link" title="Estadísticas">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </a>
            <a href="#" class="sidebar-link active" title="Usuarios">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </a>
            <a href="#" class="sidebar-link" title="Buscar">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </a>
        </nav>
    </aside>

    <!-- Main area -->
    <div class="dashboard-main">
        <!-- Top header -->
        <header class="dashboard-header">
            <div class="header-left">
                <img src="/img/ceplan-logo-white.svg" alt="CEPLAN" class="header-logo-dash" onerror="this.outerHTML='<span class=\'ceplan-text\'>CEPLAN</span>'" />
            </div>
            <div class="header-right-dash">
                <button class="btn-help-dash" title="Ayuda">?</button>
                <div class="notification-icon" title="Notificaciones">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                    <span class="notification-badge">9+</span>
                </div>
                <div class="user-menu">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><circle cx="19" cy="7" r="3" fill="#4CAF50" stroke="#4CAF50"/></svg>
                </div>
                <div class="header-user-info">
                    <span class="header-user-name">@Context.Session.GetString("UsuarioNombre")</span>
                    <span class="header-user-role">@Context.Session.GetString("UsuarioCargo")</span>
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="dashboard-content">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="gov-footer dashboard-footer">
            <div class="footer-content">
                <div class="footer-logos">
                    <div class="footer-item">
                        <span class="footer-shield">🇵🇪</span>
                        <span class="footer-peru-text">PERÚ</span>
                    </div>
                    <div class="footer-separator"></div>
                    <div class="footer-item">
                        <span class="footer-org-text">Presidencia<br/>del Consejo de<br/>Ministros</span>
                    </div>
                    <div class="footer-separator"></div>
                    <div class="footer-item">
                        <span class="footer-org-text">Centro Nacional<br/>de Planeamiento<br/>Estratégico</span>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
