@model LoginFrontend.Models.Usuario

@{
    ViewData["Title"] = "Cuenta Bloqueada";
    Layout = "_LayoutSimple";
}

<div class="w-100" style="max-width: 56rem;">
    <div class="row align-items-center g-5">
        <!-- Asymmetric Illustration Section -->
        <div class="col-md-5 d-none d-md-block">
            <div class="position-relative rounded-4 overflow-hidden bg-primary-custom d-flex align-items-center justify-content-center p-5" style="aspect-ratio: 1/1;">
                <div class="position-absolute w-100 h-100 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, #ffffff 1px, transparent 0); background-size: 24px 24px;"></div>
                <div class="position-relative z-10 d-flex flex-column align-items-center">
                    <span class="material-symbols-outlined text-white opacity-40 mb-3" style="font-size: 5rem;">lock_person</span>
                    <div class="rounded-pill bg-white opacity-60" style="height: 4px; width: 4rem;"></div>
                </div>
            </div>
        </div>
        
        <!-- Content Section -->
        <div class="col-12 col-md-7 d-flex flex-column gap-4">
            <div class="d-flex flex-column gap-3">
                <div class="d-inline-flex align-items-center gap-2 px-3 py-1 rounded-pill bg-error-container text-on-error-container fw-semibold text-uppercase tracking-wider align-self-start" style="font-size: 0.75rem;">
                    <span class="material-symbols-outlined icon-fill-1" style="font-size: 0.875rem;">security</span>
                    Protocolo de Seguridad
                </div>
                <h1 class="font-headline fw-bolder text-primary-custom tracking-tight lh-sm" style="font-size: 2.75rem;">
                    Cuenta temporalmente <br/><span class="text-error">restringida</span>
                </h1>
                <p class="text-on-surface-variant fs-5 lh-base m-0" style="max-width: 32rem;">
                    Por su seguridad, hemos bloqueado el acceso a esta cuenta tras múltiples intentos fallidos (5/5). Esta es una medida institucional estándar para prevenir el acceso no autorizado.
                </p>
            </div>
            
            <div class="bg-surface-container-low p-4 rounded-4 shadow-sm border-start border-4 border-error d-flex flex-column gap-3 mt-2">
                <h3 class="font-headline fw-bold text-primary-custom fs-5 m-0">¿Qué sucede ahora?</h3>
                <p class="text-on-surface-variant small m-0">
                    Nuestro equipo de seguridad está monitoreando la situación. La restricción se levantará automáticamente en <strong id="countdown-timer">15:00</strong>. Se ha registrado un reporte de incidente.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-2">
                    <a href="#" class="btn btn-outline-secondary px-4 py-2 border border-outline-variant fw-semibold rounded-3 hover-bg-slate-50 transition-all text-secondary-custom bg-white">
                        Mesa de Ayuda
                    </a>
                    <a href="@Url.Action("Login", "Account")" class="btn btn-light px-4 py-2 fw-semibold rounded-3 text-secondary-custom transition-all">
                        Volver al Ingreso
                    </a>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-3 mt-3 fw-medium text-uppercase tracking-widest text-on-surface-variant opacity-60" style="font-size: 0.65rem;">
                <span>ID de Referencia: IV-7702-XQ</span>
                <span class="rounded-circle bg-outline-variant" style="width: 4px; height: 4px;"></span>
                <span>Último Intento: Hace un momento</span>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.UnblockTime != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let timeStr = '@Html.Raw(ViewBag.UnblockTime)';
            let targetTime = parseInt(timeStr, 10);
            const timerElement = document.getElementById('countdown-timer');

            function updateTimer() {
                if (isNaN(targetTime) || !timeStr) {
                    // Fallback visual in case of direct refresh or missing data
                    timerElement.innerHTML = "15:00"; 
                    return;
                }
                
                const now = new Date().getTime();
                const distance = targetTime - now;

                if (distance <= 0) {
                    timerElement.innerHTML = "Desbloqueado (Actualice la página)";
                    return;
                }

                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                timerElement.innerHTML = minutes + ":" + (seconds < 10 ? "0" : "") + seconds;
            }

            updateTimer();
            if (!isNaN(targetTime) && timeStr) {
                setInterval(updateTimer, 1000);
            }
        });
    </script>
}
