@model LoginFrontend.Models.Usuario

@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutSimple";
}

<div class="w-100" style="max-width: 28rem;">
    <!-- Institutional Badge / Logo -->
    <div class="d-flex justify-content-center mb-5">
        <div class="rounded-3 premium-gradient d-flex align-items-center justify-content-center shadow-lg" style="width: 4rem; height: 4rem;">
            <span class="material-symbols-outlined text-white fs-1" data-icon="account_balance">account_balance</span>
        </div>
    </div>

    <!-- Header Text -->
    <div class="text-center mb-5">
        <h1 class="font-headline fw-bolder fs-3 text-primary-custom tracking-tight mb-2">Consola de Gestión</h1>
        <p class="text-on-surface-variant fw-medium m-0">Acceda a su portal de identidad institucional</p>
    </div>

    <!-- Login Container -->
    <div class="bg-surface-container-lowest rounded-4 p-4 p-sm-5 shadow ring-1">
        
        <!-- Tab Switcher (Simulated) -->
        <div class="d-flex bg-surface-container-low p-1 rounded-3 mb-5">
            <button type="button" class="btn border-0 flex-grow-1 py-2 fw-semibold rounded-2 bg-white text-primary-custom shadow-sm" onclick="setDocumentType('DNI', this)" id="btnDNI">DNI</button>
            <button type="button" class="btn border-0 flex-grow-1 py-2 fw-medium text-on-surface-variant hover-text-primary-custom transition-colors" onclick="setDocumentType('CE', this)" id="btnCE">CE</button>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="mb-4 bg-error-container border-start border-4 border-danger p-3 rounded-end-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-error fs-5">warning</span>
                    <p class="small text-on-error-container fw-medium m-0">@ViewBag.Error</p>
                </div>
            </div>
        }
        else if (ViewBag.IntentosRestantes != null && ViewBag.IntentosRestantes < 5 && ViewBag.IntentosRestantes > 0)
        {
            <div class="mb-4 bg-error-container border-start border-4 border-danger p-3 rounded-end-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-error fs-5">warning</span>
                    <p class="small text-on-error-container fw-medium m-0">Quedan @ViewBag.IntentosRestantes intentos antes del bloqueo temporal.</p>
                </div>
            </div>
        }

        @if (ViewBag.SessionExpired == true)
        {
            <div class="mb-4 bg-secondary-container opacity-75 border-start border-4 border-secondary p-3 rounded-end-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-secondary-custom fs-5">info</span>
                    <p class="small text-on-secondary-container fw-medium m-0">Su sesión ha expirado por inactividad. Por favor, vuelva a ingresar.</p>
                </div>
            </div>
        }

        <!-- Form -->
        <form asp-action="Login" method="post" class="d-flex flex-column gap-4">
            <input type="hidden" id="TipoDocumento" name="TipoDocumento" value="@(ViewBag.LastTipoDocumento ?? "DNI")" />

            <div>
                <label for="numeroDocumento" class="form-label small fw-semibold text-on-surface-variant mb-2">Número de Documento</label>
                <input type="text" class="form-control bg-surface-container-highest border-0 py-3 px-3 text-on-surface shadow-none" 
                       id="numeroDocumento" name="numeroDocumento" placeholder="00000000" 
                       value="@ViewBag.LastDataUser" required autocomplete="off" />
            </div>

            <div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label for="password" class="form-label small fw-semibold text-on-surface-variant m-0">Contraseña</label>
                    <a href="#" class="small fw-semibold text-secondary-custom text-decoration-none hover-underline transition-all" style="font-size: 0.75rem;">¿Olvidó su contraseña?</a>
                </div>
                <div class="position-relative">
                    <input type="password" class="form-control bg-surface-container-highest border-0 py-3 px-3 pe-5 text-on-surface shadow-none" 
                           id="password" name="password" placeholder="••••••••" required autocomplete="current-password" />
                    <button type="button" class="btn position-absolute end-0 top-50 translate-middle-y border-0 text-on-surface-variant hover-text-primary-custom" onclick="togglePasswordVisibility()">
                        <span class="material-symbols-outlined fs-5" id="toggleIcon">visibility</span>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn premium-gradient text-white font-headline fw-bold py-3 mt-3 shadow hover-scale-101 active-scale-95 transition-all w-100 rounded-3">
                Ingresar
            </button>
        </form>

        <!-- Support Footer in Card -->
        <div class="mt-5 pt-4 border-top border-outline-variant text-center">
            <p class="small text-on-surface-variant m-0" style="font-size: 0.75rem;">¿Necesita ayuda? <a href="#" class="text-secondary-custom fw-bold text-decoration-none hover-underline">Contacte al Soporte Institucional</a></p>
        </div>
    </div>

    <!-- Bottom Illustration -->
    <div class="mt-5 pt-3 d-flex align-items-center opacity-40">
        <div class="flex-grow-1 border-top border-2 border-outline-variant"></div>
        <div class="px-3" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 900; color: #0e1c2b;">Capa de Seguridad 4.0</div>
        <div class="flex-grow-1 border-top border-2 border-outline-variant"></div>
    </div>
</div>

@section Scripts {
    <script>
        function setDocumentType(type, element) {
            document.getElementById('TipoDocumento').value = type;
            
            // Switch styles
            const btnDNI = document.getElementById('btnDNI');
            const btnCE = document.getElementById('btnCE');
            
            let activeClasses = ['bg-white', 'text-primary-custom', 'shadow-sm', 'fw-semibold'];
            let inactiveClasses = ['text-on-surface-variant', 'fw-medium', 'hover-text-primary-custom'];
            
            if (type === 'DNI') {
                btnDNI.classList.add(...activeClasses);
                btnDNI.classList.remove(...inactiveClasses);
                btnCE.classList.add(...inactiveClasses);
                btnCE.classList.remove(...activeClasses);
            } else {
                btnCE.classList.add(...activeClasses);
                btnCE.classList.remove(...inactiveClasses);
                btnDNI.classList.add(...inactiveClasses);
                btnDNI.classList.remove(...activeClasses);
            }
        }

        // Initialize proper tab based on last input if available
        document.addEventListener("DOMContentLoaded", () => {
            const currentDocType = document.getElementById('TipoDocumento').value;
            if (currentDocType === 'CE') {
                setDocumentType('CE', document.getElementById('btnCE'));
            }
        });

        function togglePasswordVisibility() {
            var passwordInput = document.getElementById("password");
            var toggleIcon = document.getElementById("toggleIcon");
            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                toggleIcon.textContent = "visibility_off";
            } else {
                passwordInput.type = "password";
                toggleIcon.textContent = "visibility";
            }
        }
    </script>
}
