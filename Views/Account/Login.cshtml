@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutSimple";
}

<div class="login-card">
    <!-- Document type tabs -->
    <div class="doc-tabs">
        <button type="button" class="doc-tab active" data-tipo="DNI" id="tabDNI">DNI</button>
        <button type="button" class="doc-tab" data-tipo="CE" id="tabCE">CE</button>
    </div>

    <form method="post" asp-action="Login" asp-controller="Account" id="loginForm">
        <input type="hidden" name="tipoDocumento" id="tipoDocumento" value="@(ViewBag.TipoDocumento ?? "DNI")" />

        <!-- Usuario -->
        <div class="form-group mb-3">
            <label for="numeroDocumento" class="form-label fw-semibold">Usuario</label>
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </span>
                <input type="text" class="form-control" id="numeroDocumento" name="numeroDocumento" 
                       placeholder="Ingresar usuario" value="@ViewBag.NumeroDocumento"
                       maxlength="12" autocomplete="off" />
            </div>
        </div>

        <!-- Contraseña -->
        <div class="form-group mb-2">
            <label for="password" class="form-label fw-semibold">Contraseña</label>
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </span>
                <input type="password" class="form-control" id="password" name="password" 
                       placeholder="Ingresar contraseña" autocomplete="off" />
                <button class="btn btn-outline-secondary border-start-0 bg-white" type="button" id="togglePassword">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" id="eyeIcon">
                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="mb-3">
            <a href="#" class="forgot-link">¿Olvidó su contraseña?</a>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 text-center" role="alert">
                <small>@ViewBag.Error</small>
            </div>
        }

        @if (ViewBag.SessionExpired == true)
        {
            <div class="alert alert-warning py-2 text-center" role="alert">
                <small>Su sesión ha expirado. Por favor, inicie sesión nuevamente.</small>
            </div>
        }

        <button type="submit" class="btn btn-login w-100">Ingresar</button>
    </form>

    <div class="help-section">
        <div class="d-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#3B6CB4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
            </svg>
            <span>¿Necesita ayuda?, <a href="#" class="support-link">contacte con el área de soporte.</a></span>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Tab switching
    document.querySelectorAll('.doc-tab').forEach(tab => {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.doc-tab').forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            document.getElementById('tipoDocumento').value = this.dataset.tipo;
        });
    });

    // Set active tab on load
    const currentTipo = document.getElementById('tipoDocumento').value;
    if (currentTipo === 'CE') {
        document.getElementById('tabDNI').classList.remove('active');
        document.getElementById('tabCE').classList.add('active');
    }

    // Toggle password visibility
    document.getElementById('togglePassword').addEventListener('click', function() {
        const pwd = document.getElementById('password');
        const icon = document.getElementById('eyeIcon');
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
        } else {
            pwd.type = 'password';
            icon.innerHTML = '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>';
        }
    });
</script>
}
